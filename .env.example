# Any.Run API Configuration
# Lấy API key tại: https://app.any.run/ -> Profile -> API and Limits
ANYRUN_API_KEY=your_anyrun_api_key_here

# Cấu hình tùy chọn
OUTPUT_DIR=reports
LOG_LEVEL=INFO

# AI assistant provider
# AI_PROVIDER=local | openai | ollama | auto
AI_PROVIDER=auto
AI_TEMPERATURE=0.25
AI_MAX_TOKENS=1100
AI_TIMEOUT=45
AI_RETRIES=2
AI_CONTEXT_LIMIT=12000
AI_FAST_MODE=1

# Ollama local LLM (sau khi cài Ollama và pull model)
# Ví dụ: ollama pull llama3.1:8b
OLLAMA_ENABLED=0
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=120
OLLAMA_NUM_PREDICT=500

# OpenAI tùy chọn nếu không dùng Ollama
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
